# Copy to .env for docker-compose. Values below are the compose defaults.

# Postgres
POSTGRES_USER=covenant
POSTGRES_PASSWORD=covenant
POSTGRES_DB=covenant
DATABASE_URL=postgresql://covenant:covenant@db:5432/covenant

# Warden proxies to this upstream MCP server (inside the compose network)
UPSTREAM_MCP_URL=http://test-mcp:8000/mcp

# Ports (host side)
WARDEN_PORT=8080
TEST_MCP_PORT=8000
